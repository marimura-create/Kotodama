// 形霊SVG（ヘッダー列用・大）
function shapeSVG(v, color, size) {
  const s=size, cx=s/2, cy=s/2, r=s*0.37;
  if(v==="あ") return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}"><circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${color}" stroke-width="1.5"/></svg>`;
  if(v==="い") {
    const pts=`${cx},${cy-r} ${cx-r*.866},${cy+r*.5} ${cx+r*.866},${cy+r*.5}`;
    return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}"><polygon points="${pts}" fill="none" stroke="${color}" stroke-width="1.5"/></svg>`;
  }
  if(v==="う") {
    const d=`M ${cx} ${cy} C ${cx+r*.35} ${cy-r*.15}, ${cx+r*.65} ${cy+r*.15}, ${cx+r*.45} ${cy+r*.5} C ${cx+r*.25} ${cy+r*.85}, ${cx-r*.35} ${cy+r*.8}, ${cx-r*.65} ${cy+r*.35} C ${cx-r*.9} ${cy-r*.1}, ${cx-r*.7} ${cy-r*.65}, ${cx-r*.1} ${cy-r*.75}`;
    return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}"><path d="${d}" fill="none" stroke="${color}" stroke-width="1.5"/></svg>`;
  }
  if(v==="え") {
    const pts=Array.from({length:6},(_,i)=>{const a=(Math.PI/3)*i-Math.PI/6; return `${cx+r*Math.cos(a)},${cy+r*Math.sin(a)}`;}).join(" ");
    return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}"><polygon points="${pts}" fill="none" stroke="${color}" stroke-width="1.5"/></svg>`;
  }
  if(v==="お") {
    const side=r*1.52;
    return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}"><rect x="${cx-side/2}" y="${cy-side/2}" width="${side}" height="${side}" fill="none" stroke="${color}" stroke-width="1.5"/></svg>`;
  }
  return "";
}

// パネル用形霊SVG
function shapeSVGPanel(v, color) {
  return shapeSVG(v, color, 30);
}

