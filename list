// ── テーブル生成 ──────────────────────────────────────────
let selectedTd = null;
let selectedCell = null;
let selectedVowelIdx = null;

const tbody = document.getElementById("tbody");

ROWS.forEach(row => {
  const tr = document.createElement("tr");

  // ラベル列
  const tdLabel = document.createElement("td");
  tdLabel.className = "row-label";
  tdLabel.innerHTML = `<div><span class="row-con">${row.con}</span><span class="row-name">${row.label}</span></div><div class="row-sub">${row.sub}</div>`;
  tr.appendChild(tdLabel);

  // セル列
  row.cells.forEach((cell, vi) => {
    const td = document.createElement("td");
    td.className = "cell-td" + (cell.ghost ? " ghost" : "");
    const vkana = VOWELS[vi];
    const color = VOWEL_COLORS[vkana];
    td.innerHTML = `
      <div class="cell-inner">
        <div class="cell-kana" style="color:${cell.ghost ? "var(--reion)" : color}">${cell.k}</div>
        ${cell.nr && !cell.ghost ? `<div class="cell-numrei">【${cell.nr}】</div>` : ""}
      </div>`;

    td.addEventListener("mouseenter", () => {
      if (td !== selectedTd) showPanel(cell, vi, row, false);
    });
    td.addEventListener("mouseleave", () => {
      if (td !== selectedTd) {
        if (selectedCell) showPanel(selectedCell, selectedVowelIdx, ROWS.find(r=>r.cells.includes(selectedCell)), true);
        else clearPanel();
      }
    });
    td.addEventListener("click", () => {
      if (td === selectedTd) {
        // 解除
        selectedTd.classList.remove("selected");
        selectedTd.querySelector(".cell-inner").style.background = "";
        selectedTd.querySelector(".cell-inner").style.border = "1px solid transparent";
        selectedTd = null; selectedCell = null; selectedVowelIdx = null;
        clearPanel();
      } else {
        if (selectedTd) {
          selectedTd.classList.remove("selected");
          selectedTd.querySelector(".cell-inner").style.background = "";
          selectedTd.querySelector(".cell-inner").style.border = "1px solid transparent";
        }
        selectedTd = td; selectedCell = cell; selectedVowelIdx = vi;
        td.classList.add("selected");
        const bg = cell.ghost ? "rgba(120,60,180,.12)" : VOWEL_BG[vkana];
        const br = cell.ghost ? "1px solid rgba(140,60,200,.5)" : `1px solid ${VOWEL_BORDER[vkana]}`;
        td.querySelector(".cell-inner").style.background = bg;
        td.querySelector(".cell-inner").style.border = br;
        showPanel(cell, vi, row, true);
      }
    });

    tr.appendChild(td);
  });
  tbody.appendChild(tr);
});

function clearPanel() {
  const p = document.getElementById("panel");
  p.className = "panel";
  p.innerHTML = `<div class="panel-empty">— セルを選択すると解釈・形霊・色霊・変調が表示されます —</div>`;
}

function showPanel(cell, vi, row, isPinned) {
  const vkana = VOWELS[vi];
  const color = cell.ghost ? "var(--reion)" : VOWEL_COLORS[vkana];
  const iro   = IROTAMA[vkana];
  const kata  = KATATAMA[vkana];
  const dist  = DISTORTION[row.con];
  const p = document.getElementById("panel");
  p.className = "panel " + (cell.ghost ? "active-ghost" : "active-normal");

  let shapeSVGStr = "";
  if (!cell.ghost) {
    shapeSVGStr = `<div class="panel-shape">${shapeSVGPanel(vkana, VOWEL_COLORS[vkana].replace("var(--c-a)","#8ab0d8").replace("var(--c-i)","#e07850").replace("var(--c-u)","#80c070").replace("var(--c-e)","#5098d0").replace("var(--c-o)","#b08840"))}</div>`;
    // 色を直値で渡す
    const colorMap = {"あ":"#8ab0d8","い":"#e07850","う":"#80c070","え":"#5098d0","お":"#b08840"};
    shapeSVGStr = `<div class="panel-shape">${shapeSVG(vkana, colorMap[vkana], 30)}</div>`;
  }

  const tagsHTML =
    (cell.nr ? `<span class="tag tag-numrei">数霊：${cell.nr}</span>` : "") +
    (cell.ghost ? `<span class="tag tag-reion">深層霊音</span>` : "");

  const metaHTML = (!cell.ghost) ? `
    <div class="panel-meta">
      <span>形霊：</span>${kata.name}（${kata.desc}）${row.con !== "ー" ? ` → ${dist}` : ""}
      &ensp;<span>色霊：</span>${iro.name}（${iro.desc}）
    </div>` : "";

  p.innerHTML = `
    <div style="display:flex;flex-direction:column;align-items:center;gap:.2rem;min-width:44px">
      <div class="panel-kana" style="color:${color};text-shadow:0 0 16px ${color}44">${cell.k}</div>
      ${shapeSVGStr}
    </div>
    <div class="panel-right">
      <div class="panel-tags">
        <span class="panel-meaning" style="color:${cell.ghost?"#b090d0":"#d4b870"}">${cell.m}</span>
        ${tagsHTML}
      </div>
      <div class="panel-desc">${cell.d}</div>
      ${metaHTML}
    </div>`;
}

